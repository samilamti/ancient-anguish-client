<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Chosen's MUD Client for Ancient Anguish</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Chosen's MUD Client for Ancient Anguish</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<!--
	  The app uses only standard TLS/HTTPS via Apple-provided frameworks
	  (no custom crypto, no proprietary protocols), which qualifies for
	  the exemption under EAR 740.17(b)(2). Declaring this here makes
	  every TestFlight upload skip the manual "Export Compliance" gate
	  in App Store Connect.
	-->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!--
	  Privacy purpose strings. NSPhotoLibraryUsageDescription is a real
	  user-facing feature: Area Configuration lets you assign a background
	  image to a MUD area by picking from your Photos. The other entries
	  exist only because file_picker links DKImagePickerController /
	  DKPhotoGallery — those symbols reference camera / microphone /
	  photo-add APIs that the app never actually invokes, but Apple's
	  static analysis still requires a purpose string for each.
	-->
	<key>NSAppleMusicUsageDescription</key>
	<string>Pick tracks from your Music library to use as area music or battle themes.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Pick a photo from your library to use as a background image for a MUD area.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>This app does not save photos. This permission is required by a bundled file-picker library.</string>
	<key>NSCameraUsageDescription</key>
	<string>This app does not use the camera. This permission is required by a bundled file-picker library.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>This app does not use the microphone. This permission is required by a bundled file-picker library.</string>
</dict>
</plist>
